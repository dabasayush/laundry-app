{
  "expo": {
    "name": "Laundry",
    "slug": "laundry-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.laundry.mobile"
    },
    "android": {
      "package": "com.laundry.mobile"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Laundry to access your location to auto-fill your address.",
          "isAndroidForegroundServiceEnabled": false
        }
      ]
    ],
    "scheme": "laundry",
    "extra": {
      "eas": {
        "projectId": "laundry-mobile"
      }
    }
  }
}
