# Admin Panel Environment Variables
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
API_BASE_URL=http://localhost:4000
API_ADMIN_TOKEN=your_internal_admin_service_token

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change_me_nextauth_secret

# Cloudinary (for image uploads in Services and Products)
# 1. Go to https://cloudinary.com and create a free account
# 2. Find your Cloud Name in the dashboard
# 3. Create an unsigned upload preset: Settings > Upload > Add upload preset (set to Unsigned)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset
