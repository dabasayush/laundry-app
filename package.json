{
  "name": "laundry-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm --workspace @laundry/api run dev",
    "dev:admin": "npm --workspace @laundry/admin run dev",
    "dev:mobile": "npm --workspace @laundry/mobile start",
    "dev:driver": "npm --workspace @laundry/driver start",
    "build:api": "npm --workspace @laundry/api run build",
    "build:admin": "npm --workspace @laundry/admin run build",
    "db:migrate": "npm --workspace @laundry/api run db:migrate",
    "db:seed": "npm --workspace @laundry/api run db:seed",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.4.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "es-abstract": "^1.23.9",
    "eslint": "^8.57.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "description": "",
  "main": "index.js",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^7.4.2",
    "@radix-ui/react-context": "^1.1.3",
    "axios": "^1.13.6",
    "prisma": "^7.4.2",
    "react-query": "^3.39.3",
    "redis": "^5.11.0",
    "tailwindcss": "^4.2.1",
    "zod": "^3.25.76"
  },
  "overrides": {
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.74.0"
  }
}
